{
  "manifest_version": 3,
  "name": "Tính Điểm",
  "version": "1.0",
  "description": "Tiện ích tính điểm đạt/không đạt cho sinh viên IT.",
  "permissions": [],
  "action": {
    "default_popup": "index.html",
    "default_title": "Tính Điểm IT",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "sidebar_action": {
    "default_panel": "index.html",
    "default_title": "Tính Điểm IT"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tinh-diem-it@antigravity.ai"
    }
  }
}
